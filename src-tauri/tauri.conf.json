{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disc Xplorer",
  "version": "0.9.6",
  "identifier": "com.jaguar.optical-disc-explorer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Disc Xplorer",
        "width": 1100,
        "height": 650,
        "theme": null
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDRUNGQjA2NEFCNTcyRjkKUldUNWNyVktCdnZzak9td2U2SVBYRitmamFSY04ySVNGSGt5SXdPZE53VDk1cDVmb0x1VDMrZ3cK",
      "endpoints": [
        "https://github.com/whatev-indus/disc-xplorer/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "appimage", "dmg"],
    "externalBin": ["binaries/redumper"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
