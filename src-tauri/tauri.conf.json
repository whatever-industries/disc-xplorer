{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disc Xplorer",
  "version": "1.3.0",
  "identifier": "com.jaguar.optical-disc-explorer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Disc Xplorer",
        "width": 1100,
        "height": 650,
        "theme": null
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "appimage"],
    "externalBin": ["binaries/redumper"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
